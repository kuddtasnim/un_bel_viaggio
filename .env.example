# Скопируй этот файл в .env и заполни своими значениями
# НИКОГДА не добавляй .env в GitHub (он уже в .gitignore)

# Секретный ключ для JWT токенов — придумай любую длинную случайную строку
JWT_SECRET=замени_на_случайную_строку_минимум_32_символа

# Токен Hugging Face (получен на huggingface.co)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Ключ Google Maps
GOOGLE_MAPS_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Порт сервера (Railway подставит автоматически)
PORT=3000

# Среда (development или production)
NODE_ENV=development
